# ============================================================
# Manila Flood Forecast - Environment Variables Template
# Copy this file to .env and fill in real values. Never commit .env.
# ============================================================

# --- Application ---
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-random-string

# --- Backend API ---
API_HOST=127.0.0.1
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000

# --- Database (PostgreSQL + PostGIS, installed locally) ---
POSTGRES_USER=flood_user
POSTGRES_PASSWORD=change-me
POSTGRES_DB=manila_flood
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://flood_user:change-me@localhost:5432/manila_flood

# --- Redis Cache (installed locally) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# --- ML Model ---
MODEL_PATH=../ml/artifacts/multi_stream_cnn_lstm.keras
MODEL_VERSION=v0.1.0
MLFLOW_TRACKING_URI=http://localhost:5000

# --- External Data Sources ---
PAGASA_API_KEY=
NOAA_API_KEY=

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_MAPBOX_TOKEN=
